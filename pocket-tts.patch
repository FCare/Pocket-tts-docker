+):
+    """
+    Convert an uploaded audio file to a cached voice embedding (.safetensors).
+    The stored voice can then be used in /tts via voice_url=<name>.
+    """
+    if not name.strip() or "/" in name or "\\" in name:
+        raise HTTPException(status_code=400, detail="Invalid voice name")
