+    with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
+        tmp.write(voice_wav.file.read())
+        tmp_path = tmp.name
+
+    try:
+        with _inference_lock:
+            model_state = tts_model.get_state_for_audio_prompt(Path(tmp_path), truncate=True)
+        export_model_state(model_state, dest)
+    finally:
+        os.unlink(tmp_path)
+
+    return {"name": name, "path": str(dest)}
